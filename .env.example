# Supabase — get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Never expose this on the client — server-side only (Route Handlers, Server Actions)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Privy — Admin panel authentication (https://dashboard.privy.io)
# Get this from: Privy Dashboard → your app → Settings → App ID
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id-here
